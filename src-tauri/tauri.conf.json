{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw Connector",
  "version": "0.3.0",
  "identifier": "ai.openclaw.connector",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5187"
  },
  "app": {
    "windows": [
      {
        "title": "OpenClaw 连接器",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
