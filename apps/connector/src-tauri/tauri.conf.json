{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw Connector",
  "version": "0.1.0",
  "identifier": "ai.openclaw.connector",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "OpenClaw Connector",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": ["app"]
  }
}
